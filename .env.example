# Required: generate with `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"`
FERNET_KEY=

# Required by default. Use a long random value (for example: `openssl rand -hex 32`).
API_AUTH_TOKEN=
# Optional additional tokens (comma-separated or JSON array). Full admin access each.
# API_AUTH_TOKENS=operator-a-token,operator-b-token
# Optional named keys with scopes (JSON array). Scopes: read, scan, admin (admin > scan > read).
# API_AUTH_KEYS=[{"id":"reader","label":"Read only","token":"...","scopes":["read"]},{"id":"ops","label":"Scanner","token":"...","scopes":["scan"]}]
API_AUTH_REQUIRED=true
API_AUTH_HEADER=X-API-KEY

# Network and workload limits
APP_HOST=127.0.0.1
APP_PORT=5000
MAX_CONCURRENT_SCANS=2
MAX_SCHEDULED_TASKS=100
MAX_SCAN_JOBS=200
MAX_REQUESTS_PER_WINDOW=10
MAX_RATE_LIMIT_CLIENTS=10000
RATE_LIMIT_WINDOW_SECONDS=60
# Optional shared rate limits for multi-worker deploys (empty = in-process memory).
# REDIS_URL=redis://127.0.0.1:6379/0
# REDIS_RATE_LIMIT_PREFIX=recon_operator:rl:
# Include API-key owner hash in rate-limit buckets (recommended multi-token).
RATE_LIMIT_INCLUDE_OWNER=true
MAX_REQUEST_BODY_BYTES=1048576
MAX_TARGET_ADDRESSES=4096
# Optional engagement scope. Empty = unrestricted. Comma list, JSON array, and/or file.
# TARGET_ALLOWLIST=127.0.0.1,10.0.0.0/8,lab.example.com,*.corp.internal
# TARGET_ALLOWLIST_FILE=/path/to/allowlist.txt
MIN_SCHEDULE_INTERVAL_MINUTES=1
MAX_SCHEDULE_INTERVAL_MINUTES=10080
SCAN_TIMEOUT_SECONDS=1800
NMAP_HOST_TIMEOUT_SEC=300
NMAP_MAX_RETRIES=2

# Persistence and optional integrations
RESULTS_DIR=encrypted_results
RESULTS_MAX_FILES=500
RESULTS_MAX_AGE_DAYS=0
# When false, pre-1.7 result files without an owner prefix are hidden (recommended for multi-token deploys).
LEGACY_RESULTS_SHARED=true
MAX_IMPORT_XML_BYTES=67108864
STATE_DB_PATH=data/recon_operator.db
AI_REPORTS_MAX_DIRS=100
AI_REPORTS_MAX_AGE_DAYS=0
SCAN_LOG_PATH=logs/scan_log.txt
TOOL_INVENTORY_CACHE_SECONDS=300
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
INITIAL_TASKS=[]
